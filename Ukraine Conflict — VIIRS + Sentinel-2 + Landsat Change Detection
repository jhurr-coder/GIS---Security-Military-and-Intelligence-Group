//// ----------------- Sentinel-2: Agricultural NDVI Monitoring ----------------- ////

function addNDVI_S2(image) {
  var ndvi = image.normalizedDifference(['B8','B4']).rename('NDVI');
  return image.addBands(ndvi);
}

var S2 = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
  .filterBounds(kharkiv)
  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 20))
  .map(maskS2clouds)
  .map(addNDVI_S2);

// Pre-invasion baseline (2019-2021)
var S2_baseline = S2.filterDate('2019-06-01', '2021-09-30').median();

// Conflict growing seasons (2022-2024)
var S2_conflict = S2.filterDate('2022-06-01', '2024-09-30').median();

// NDVI difference
var S2_ndvi_diff = S2_conflict.select('NDVI')
                    .subtract(S2_baseline.select('NDVI'))
                    .rename('NDVI_diff');

var ndvi_vis      = {bands:'NDVI', min:0,    max:0.8,  palette:['white','lightgreen','darkgreen']};
var ndvi_diff_vis = {              min:-0.4, max:0.4,  palette:['red','white','green']};

Map.addLayer(S2_baseline,   ndvi_vis,      "S2 NDVI Baseline (2019-21)",         false);
Map.addLayer(S2_conflict,   ndvi_vis,      "S2 NDVI Conflict (2022-24)",          false);
Map.addLayer(S2_ndvi_diff,  ndvi_diff_vis, "S2 NDVI Change (Conflict-Baseline)",  true);

// Sentinel-2 NDVI time series for Kharkiv
var S2_ndvi_chart = ui.Chart.image.series({
  imageCollection: S2.filterDate('2016-01-01', '2024-12-31').select('NDVI'),
  region:          kharkiv,
  reducer:         ee.Reducer.mean(),
  scale:           100,
  xProperty:       'system:time_start'
}).setOptions({
  title:     'Kharkiv Region NDVI — Sentinel-2 (2016–2024)',
  vAxis:     {title: 'NDVI'},
  hAxis:     {title: 'Date'},
  lineWidth: 1,
  colors:    ['green']
});

print(S2_ndvi_chart);


//// ----------------- Composite Overlay: Lights + Agriculture ----------------- ////

// Normalize both difference layers then combine
// High value = area lost BOTH nighttime light AND vegetation health
var light_loss = VIIRS_diff.unitScale(-40, 10).multiply(-1);  // invert: high = more loss
var veg_loss   = S2_ndvi_diff.unitScale(-0.4, 0.4).multiply(-1); // invert: high = more loss

var dual_loss  = light_loss.add(veg_loss).rename('dual_loss');

Map.addLayer(dual_loss, {min:0, max:2, palette:['white','orange','darkred']},
             "Dual Loss: Lights + Vegetation", true);

